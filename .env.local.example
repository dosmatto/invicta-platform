# Sincronização na nuvem (Firebase) — OPCIONAL.
# Sem estas variáveis o app roda 100% local (localStorage), como antes.
#
# Onde pegar: console.firebase.google.com > seu projeto > Configurações do
# projeto > Seus apps > app Web > "Configuração do SDK". Copie este arquivo
# para .env.local (dev) e cadastre as mesmas variáveis na Vercel (produção).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Supabase (migração Auth/dados — Fase 3) — OPCIONAL nesta etapa ──
# A `anon key` é pública (vai no front, protegida por RLS). A `service_role key`
# NÃO entra aqui — ela só é usada em script de migração no servidor/local.
# Onde pegar: app.supabase.com > projeto invicta-prod > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Interruptor dos DADOS (separado do login). Com "true", o app lê/grava os dados
# no Postgres do Supabase (tabelas app_kv + talhoes) em vez do Firestore.
# Só ligar DEPOIS de importar os dados existentes (senão a base aparece vazia).
NEXT_PUBLIC_USE_SUPABASE_DATA=

# ── Proteção anti-abuso do backend (Render) — OPCIONAL, 100% opt-in ──
# Sem esta variável o front não envia nenhum header extra (zero mudança de
# comportamento). Defina o MESMO valor de INVICTA_API_KEY (configurada no
# Render, não aqui) para o front passar a enviar X-Api-Key nas chamadas ao
# backend. ATENÇÃO: valor NEXT_PUBLIC_* vai para o bundle do client — é
# proteção anti-abuso casual (bots batendo direto na URL pública), não é
# segurança forte. Não reutilize senhas/segredos sensíveis aqui.
NEXT_PUBLIC_INTERP_API_KEY=

# As variáveis abaixo são configuradas SÓ no Render (backend), não aqui:
#   INVICTA_API_KEY           — chave compartilhada; vazia = sem auth (atual).
#   INVICTA_ALLOWED_ORIGINS   — lista de origens CORS separada por vírgula;
#                               vazia = libera qualquer origem ["*"] (atual).
